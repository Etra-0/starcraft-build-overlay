{
  "name": "bw-build-overlay-suite",
  "version": "1.0.0",
  "description": "An always-on-top build-order overlay and Liquipedia importer for StarCraft: Remastered / Brood War. Cross-platform: Windows, macOS, Linux.",
  "type": "module",
  "author": "Etra-0",
  "license": "MIT",
  "homepage": "https://github.com/Etra-0/starcraft-build-overlay#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Etra-0/starcraft-build-overlay.git"
  },
  "bugs": {
    "url": "https://github.com/Etra-0/starcraft-build-overlay/issues"
  },
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=11.0.0"
  },
  "scripts": {
    "clean": "rimraf dist-frontend src-tauri/target",
    "build:renderer": "node scripts/build-renderer.mjs",
    "dev:renderer": "node scripts/build-renderer.mjs --watch",
    "dev": "node scripts/dev.mjs",
    "tauri": "tauri",
    "tauri:dev": "node scripts/dev.mjs",
    "tauri:build": "tauri build",
    "dist": "tauri build",
    "dist:win": "tauri build --bundles nsis,msi",
    "dist:mac": "tauri build --bundles dmg,app",
    "dist:linux": "tauri build --bundles appimage,deb",
    "typecheck": "tsc -p tsconfig.renderer.json --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "cargo test --manifest-path src-tauri/Cargo.toml",
    "size": "node scripts/report-size.mjs",
    "release:patch": "node scripts/release.mjs patch",
    "release:minor": "node scripts/release.mjs minor",
    "release:major": "node scripts/release.mjs major"
  },
  "devDependencies": {
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/cli": "^2.11.0",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "esbuild": "^0.28.0",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3"
  }
}
